{
  "name": "@capire/sflight",
  "version": "1.0.0",
  "private": true,
  "description": "CAP flight demo scenario",
  "license": "SAP SAMPLE CODE LICENSE",
  "repository": "https://github.com/SAP-samples/cap-sflight",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "npx eslint .",
    "start": "cds-serve",
    "build:ui": "npm run build --prefix app/travel_analytics && npm run build --prefix app/travel_processor",
    "test": "jest",
    "test:mocha": "npx -y mocha",
    "travel-processor": "cds watch --open sap.fe.cap.travel/index.html?sap-ui-xx-viewCache=false",
    "travel-analytics": "cds watch --open sap.fe.cap.travel_analytics/index.html?sap-ui-xx-viewCache=false",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@cap-js/hana": ">=2",
    "@sap/cds": ">=9.1",
    "@sap/hana-client": "^2.25.29",
    "@sap/xsenv": "^6.0.0",
    "@sap/xssec": "^4.9.0",
    "express": "^4",
    "passport": "^0.7.0",
    "patch-package": "^8.0.0",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "cds-plugin-ui5": "^0.13.6",
    "@cap-js/cds-test": "^0",
    "@cap-js/cds-typer": "^0.35.0",
    "@cap-js/cds-types": "^0",
    "@cap-js/sqlite": ">=2",
    "@sap/cds-dk": ">=9.1",
    "@sap/ux-specification": "UI5-1.128",
    "@types/jest": "^29.5.13",
    "better-sqlite3": "^12.2.0",
    "cds-launchpad-plugin": "^2.2.0",
    "cross-spawn": "^7.0.3",
    "eslint": "^9",
    "http-proxy": "^1.18.1",
    "jest": "^29.0.2",
    "qunit": "^2.9.3",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.12.2"
  },
  "cds": {
    "launchpad": {
      "version": "1.141.0"
    },
    "requires": {
      "[production]": {
        "db": {
          "kind": "hana"
        },
        "auth": {
          "kind": "xsuaa"
        },
        "telemetry": {
          "kind": "to-cloud-logging"
        }
      },
      "[hybrid]": {
        "db": {
          "kind": "hana"
        }
      },
      "[development]": {
        "auth": {
          "kind": "mocked-auth",
          "users": {
            "rose": {
              "roles": []
            },
            "martha": {
              "roles": [
                "reviewer"
              ]
            },
            "amy": {
              "roles": [
                "processor"
              ]
            },
            "admin": {
              "password": "admin",
              "roles": [
                "admin"
              ]
            }
          }
        }
      }
    },
    "fiori": {
      "wrap_multiple_errors": false
    },
    "build": {
      "[production]": {
        "target": "gen",
        "tasks": [
          {
            "for": "nodejs"
          },
          {
            "for": "typescript"
          },
          {
            "for": "hana"
          }
        ]
      }
    },
    "typer": {
      "output_directory": "@cds-models",
      "use_entities_proxy": true
    }
  },
  "jest": {
    "preset": "ts-jest",
    "globalSetup": "./test/setup.ts",
    "testEnvironment": "node",
    "testTimeout": 20000
  },
  "sapux": [
    "app/travel_processor",
    "app/travel_analytics"
  ],
  "workspaces": [
    "app/*"
  ],
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  }
}
