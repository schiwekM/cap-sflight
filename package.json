{
  "name": "@capire/sflight",
  "version": "1.0.0",
  "private": true,
  "description": "CAP flight demo scenario",
  "license": "SAP SAMPLE CODE LICENSE",
  "repository": "https://github.com/SAP-samples/cap-sflight",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "lint": "npx eslint .",
    "start": "cds-serve",
    "postinstall": "patch-package",
    "test": "jest"
  },
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": ">9.0.0",
    "@sap/cds-plugin-enterprise-search": "^3.1.2",
    "@sap/xssec": "^4.9.0",
    "express": "^4",
    "patch-package": "^8.0.1",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "@cap-js/cds-typer": "^0.38.0",
    "@cap-js/cds-types": "^0",
    "@cap-js/sqlite": ">=2",
    "@sap-vt/launchpad": "file:./_launchpad_plugin",
    "@sap/cds-dk": ">=9.1",
    "@sap/ux-specification": "UI5-1.128",
    "cds-launchpad-plugin": "^2.2.0",
    "cds-plugin-ui5": "^0.13.6",
    "chai": "^6.2.1",
    "eslint": "^9",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.12.2",
    "undici-types": "^7.16.0"
  },
  "cds": {
    "features": {
      "skip_apply_parsing": true
    },
    "launchpad": {
      "version": "1.142.1",
      "template": "async"
    },
    "requires": {
      "[production]": {
        "db": {
          "kind": "hana"
        },
        "auth": {
          "kind": "xsuaa"
        },
        "telemetry": {
          "kind": "to-cloud-logging"
        }
      },
      "[development]": {
        "auth": {
          "kind": "mocked-auth",
          "users": {
            "rose": {
              "roles": []
            },
            "martha": {
              "roles": [
                "reviewer"
              ]
            },
            "amy": {
              "roles": [
                "processor"
              ]
            },
            "admin": {
              "password": "admin",
              "roles": [
                "admin"
              ]
            }
          }
        }
      }
    },
    "fiori": {
      "wrap_multiple_errors": false
    },
    "build": {
      "[production]": {
        "target": "gen",
        "tasks": [
          {
            "for": "nodejs"
          },
          {
            "for": "typescript"
          },
          {
            "for": "hana"
          },
          {
            "for": "workzone"
          }
        ]
      }
    },
    "typer": {
      "output_directory": "@cds-models",
      "use_entities_proxy": true
    }
  },
  "jest": {
    "preset": "ts-jest",
    "globalSetup": "./test/setup.ts",
    "testEnvironment": "node",
    "testTimeout": 20000
  },
  "sapux": [
    "app/travel_processor",
    "app/travel_analytics"
  ],
  "workspaces": [
    "app/*"
  ],
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  }
}
