  "version": "0.2.0",
  "configurations": [
    {
      "command": "cds build --production",
      "name": "cds build",
      "request": "launch",
      "type": "node-terminal"
    },
    {
      "command": "cds watch",
      "name": "cds watch",
      "request": "launch",
      "type": "node-terminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "command": "cds watch --profile hybrid",
      "name": "cds watch hybrid",
      "request": "launch",
      "type": "node-terminal",
      "skipFiles": ["<node_internals>/**"]
    },
  ]
}
